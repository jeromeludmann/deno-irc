{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "mod.ts",
    "client.ts",
    "core/**/*.ts",
    "plugins/**/*.ts",
    "runtime/**/*.ts"
  ],
  "exclude": [
    "**/*_test.ts",
    "testing/**"
  ]
}
