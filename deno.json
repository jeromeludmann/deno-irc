{
  "name": "@irc/client",
  "version": "0.18.2",
  "exports": "./mod.ts",
  "license": "MIT",
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "core/",
      "plugins/",
      "testing/"
    ]
  },
  "test": {
    "include": [
      "core/",
      "plugins/"
    ]
  },
  "lint": {
    "include": [
      "core",
      "plugins",
      "testing"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "tasks": {
    "lint": "deno lint **/*.ts",
    "fmt": "deno fmt **/*.ts",
    "test": "deno test --failfast core/*_test.ts plugins/*_test.ts --parallel",
    "coverage": "rm -rf coverage && deno test --parallel --coverage=coverage/cov_profile core/*_test.ts plugins/*_test.ts && deno coverage --exclude=\"_test.ts\" --exclude=\"/testing/\"",
    "test:e2e": "docker compose -f e2e/docker-compose.yml up -d --force-recreate && sleep 2 && deno test --allow-net e2e/e2e_test.ts --failfast ; docker compose -f e2e/docker-compose.yml down"
  },
  "publish": {
    "include": [
      "core",
      "plugins",
      "README.md",
      "API.md",
      "deno.json",
      "deno.lock",
      "LICENSE",
      "client.ts",
      "mod.ts"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/fmt": "jsr:@std/fmt@^1.0.2"
  }
}
